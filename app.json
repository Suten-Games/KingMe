{
  "expo": {
    "name": "KingMe",
    "slug": "kingme",
    "version": "0.3.0",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0e1a"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 23
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-asset",
      "expo-router"
    ],
    "scheme": "kingme",
    "extra": {
      "eas": {
        "projectId": "8cbb5746-d804-4c96-b46d-3c20fb774cab"
      }
    },
    "android": {
      "package": "com.saxthefiver.kingme",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "ios": {
      "bundleIdentifier": "com.saxthefiver.kingme",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}
