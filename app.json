{
  "expo": {
    "icon": "./assets/images/icon.png",
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 23
          }
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "scheme": "kingme",
    "extra": {
      "eas": {
        "projectId": "8cbb5746-d804-4c96-b46d-3c20fb774cab"
      }
    },
    "android": {
      "package": "com.saxthefiver.kingme",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      }
    },
    "ios": {
      "bundleIdentifier": "com.saxthefiver.kingme",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}
